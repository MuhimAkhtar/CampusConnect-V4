# =========================================
# CampusConnect — Environment Variables
# Copy this file to .env and fill in values
# =========================================

# Flask Secret Key (change this!)
SECRET_KEY=campusconnect_super_secret_2024_xyz

# ---- MongoDB Atlas ----
# Get from: https://cloud.mongodb.com > Connect > Drivers
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/campusconnect
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/campusconnect

# ---- Cloudflare R2 ----
# 1. Go to https://dash.cloudflare.com > R2 Object Storage
# 2. Create a bucket named "campusconnect"
# 3. Go to Manage R2 API Tokens > Create Token (Object Read & Write)
# 4. Your Account ID is shown on the R2 dashboard home page
R2_ACCOUNT_ID=your_cloudflare_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_BUCKET_NAME=campusconnect
# Public URL: enable "Public access" on your R2 bucket OR use a custom domain
# Example: https://pub-xxxx.r2.dev  OR  https://files.yourcampusconnect.com
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXX.r2.dev

# ---- Gmail SMTP (OTP Emails) ----
MAIL_USERNAME=campusconnect.noreplygmail@gmail.com
MAIL_PASSWORD=cbcyfsidpylvjqmm
